# HPCAgent-Bench Fortran formatting (fprettify). Repo-wide 120-column limit (matching
# .clang-format for C/C++ and .style.yapf for Python). Enforced on changed files
# by the CI `format-check` job (scripts/check_format.py), which passes this file
# via `fprettify --config .fprettify.rc`.
[fprettify]
line-length=120
indent=2
whitespace=2
