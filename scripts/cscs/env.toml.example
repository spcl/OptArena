# CSCS Alps Container Engine (EDF) template for the 3-tier campaign.
# Copy to env.toml, fill the image + scratch paths, then:
#   sbatch -A <account> --nodes=$N scripts/cscs/run_campaign.sbatch
# The sbatch passes this file to every srun as `--environment=<this>` (enroot/Pyxis).
#
# IMPORTANT on Alps:
#  * The compute nodes are GH200 quads -> aarch64 (ARM64 Grace). The image MUST be an
#    arm64/aarch64 build; an x86_64 image will not run. Build off-cluster (podman/
#    Docker buildx --platform linux/arm64) and push to a registry, or `enroot import`
#    it to a SquashFS on scratch (`image = "/capstor/.../optarena.sqsh"`).
#  * `-A <account>` is mandatory (or export SBATCH_ACCOUNT before sbatch).
#  * One fat image can serve all three tiers (agent + judge carry the frameworks;
#    the vLLM tier needs torch+vllm). If you split it, point the sbatch's per-role
#    srun at a per-role EDF instead of this single ENV_TOML.

# OCI image reference (registry path) OR an absolute SquashFS path on scratch.
image = "jfrog.svc.cscs.ch#<your-namespace>/optarena:aarch64-latest"

# Bind scratch + the repo so results/caches persist and the code is visible in-container.
mounts = [
    "/capstor/scratch/cscs/${USER}:/scratch",
    "${OPTARENA_REPO}:${OPTARENA_REPO}",
]
workdir = "${OPTARENA_REPO}"
writable = true

[annotations]
# Slingshot/CXI libfabric provider injection (needed for MPI-track kernels AND for the
# vLLM tier's cross-node NCCL over the high-speed fabric).
com.hooks.cxi.enabled = "true"
# aws-ofi-nccl hook: routes NCCL over libfabric/CXI so multi-node vLLM (Ray + one
# `vllm serve` spanning VLLM_NODES) does not fall back to slow TCP. Drop if VLLM_NODES=1.
com.hooks.aws_ofi_nccl.enabled = "true"
com.hooks.aws_ofi_nccl.variant = "cuda12"

[env]
# Keep HF model/tokenizer caches on scratch (not the tiny home quota).
HF_HOME = "/scratch/hf"
# hwloc GPU-probe plugins hang the topology probe in some sandboxes (see docs/RUNTIME.md).
HWLOC_COMPONENTS = "-opencl,-levelzero,-gl"
