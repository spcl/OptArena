# optarena container image (hand-maintained).
# Hardware: nvidia   network(runtime): allowed
# MPI: MPICH (OptArena MPI-track default; ABI-compatible with cray-mpich / Slingshot-CXI
# on the cluster). MPICH-in-container approach follows SPCL's XaaS containers artifact
# (github.com/spcl/xaas-containers-artifact, Copik et al.).
# NCCL (libnccl2 + libnccl-dev): GPU collective lib for GPU-initiated comms in a distributed
# device-residency kernel_mpi. nvcc + CUDA runtime come from nvidia-cuda-toolkit.
Bootstrap: docker
From: ubuntu:26.04

%files
    requirements/nvidia.txt /requirements/nvidia.txt
    containers/build-hptt.sh /build-hptt.sh

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends python3 python3-pip python3-venv python3-dev gcc g++ gfortran clang flang gdb valgrind linux-tools-common ca-certificates git curl wget openssh-client gnupg ripgrep fd-find jq less tree htop unzip vim nano libopenblas-dev liblapack-dev libfftw3-dev libhdf5-dev libnetcdf-dev libgsl-dev libeigen3-dev libsuitesparse-dev libmetis-dev mpich libmpich-dev libscalapack-mpich-dev libpetsc-real-dev libsuperlu-dev libmumps-seq-dev libhypre-dev libsundials-dev libboost-all-dev libblis-dev libucx-dev liblapacke-dev libomp-dev libtbb-dev libsleef-dev libxsimd-dev libhwy-dev libnuma-dev libhwloc-dev libarmadillo-dev libfftw3-mpi-dev make cmake pkg-config nvidia-cuda-toolkit libnccl2 libnccl-dev
    rm -rf /var/lib/apt/lists/*
    # HPTT (tensor transpose): not in apt -- build the portable CPU-scalar lib to /usr/local
    # so agents can -lhptt. See containers/LIBRARIES.md.
    sh /build-hptt.sh
    # mpi4py: source-build against MPICH -- --no-binary honors MPICC (needs python3-dev); the
    # prebuilt wheel is multi-ABI and auto-selects OpenMPI at runtime. See cpu.def.
    export MPICC=mpicc.mpich
    python3 -m pip install --break-system-packages --no-cache-dir --no-binary=mpi4py -r /requirements/nvidia.txt

%environment
    export LC_ALL=C

%runscript
    exec "$@"
