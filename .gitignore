# --- Generated benchmark artifacts (NOT committed) ---------------------------
# A kernel's framework siblings are regenerated from <kernel>_numpy.py (the
# source of truth) -- lazily by the framework loaders (run_benchmark.py emits a
# missing sibling on demand) or in bulk via scripts/emit_all_siblings.py. They
# are deterministic, so the repo keeps only the numpy reference + manifest +
# hand-written overrides. A HAND override at one of these canonical names is
# committed explicitly with `git add -f <file>`.
hpcagent_bench/benchmarks/**/*_dace.py
hpcagent_bench/benchmarks/**/*_cupy.py
hpcagent_bench/benchmarks/**/*_numba_n.py
hpcagent_bench/benchmarks/**/*_numba_np.py
hpcagent_bench/benchmarks/**/*_pythran.py
# JAX is auto-generated for ALL kernels (numpyto_jax); the only committed
# *_jax.py are hand overrides for legacy (microbench) kernels, force-added.
# (TVM/Triton have NO auto-translator, so they are NOT ignored -- their
# committed hand siblings, microbench only, are the sole source.)
hpcagent_bench/benchmarks/**/*_jax.py
hpcagent_bench/benchmarks/**/*_auto.py
# Native (C/C++/Fortran) siblings: <short>[_<sparse>]_<fptype>.<ext> + the
# <module>_cpp.py wrapper + the per-precision binding JSON, all generated on
# demand from <short>_numpy.py. The repo commits none; a HAND override at one of
# these names is committed with `git add -f`.
hpcagent_bench/benchmarks/**/*_cpp.py
hpcagent_bench/benchmarks/**/cpp_backend/*.c
hpcagent_bench/benchmarks/**/cpp_backend/*.cpp
hpcagent_bench/benchmarks/**/cpp_backend/*.f90
hpcagent_bench/benchmarks/**/cpp_backend/*_binding.json
hpcagent_bench/benchmarks/**/cpp_backend/*.so
hpcagent_bench/benchmarks/**/cpp_backend/build/
hpcagent_bench/benchmarks/**/cpp_backend/build-clang/

# Pluto polyhedral-optimizer intermediates (the committed *_pluto_input.c are the
# INPUTS and stay; .pluto.cloog is a generated artifact -- never commit it).
*.pluto.cloog

# HuggingFace dataset export (hpcagent-bench export-hf). The dataset is a pure
# regenerator over the manifest tree -- never cached in the repo (the CI workflow
# rebuilds + publishes it). The default local output stays out of git.
hpcagent_bench_hf.parquet
hpcagent_bench_hf.jsonl

# Harbor adapter: generated task directories (regenerated from the kernel suite by
# adapters/hpcagent_bench/run_adapter.py -- never committed).
adapters/hpcagent_bench/tasks/

# --- Local run scratch (machine-specific; never committed) --------------------
# Hardware/CPU dumps, agent run outputs, and SDFG/visualization scratch left by
# local runs. A fresh clone should not carry any of these.
dmidecode_output
agent_out/
_dacegraphs/
_session_scratch/

# Local-only dev tools (kept on disk, not published)
scripts/infer_output_args.py
scripts/verify_tvm.py
tools/pluto_affine_survey_results.txt

# Native (no-container) run scratch -- keep the folder, ignore its contents.
hpcagent_bench/native_runs/*
!hpcagent_bench/native_runs/.gitkeep

# --- Build / cache artifacts (machine-generated; never committed) -------------
# GT4Py kernel cache, compiled Fortran modules, ruff cache.
.gt_cache/
*.mod
.ruff_cache/

# Paper draft (working artifact, not part of the repo)
paper/

# Transient handover / handoff notes (local-only scratch, not part of the repo)
HANDOFF_ISSUES/

# Never commit key / secret material anywhere in this repo.
*.pem
*.key
*_key
id_rsa*
id_ed25519*
id_ecdsa*
*.ppk
.ssh/
*.p12
*.pfx

# Optional compiler diagnostics (hpcagent_bench/perf_reports.py): vectorization reports +
# objdump disassembly, produced only when $HPCAGENT_BENCH_PERF_REPORTS_* is switched on.
# Build OUTPUT of a local run mirroring the benchmark tree -- regenerable from the
# sources, host-specific (-march=native decides which loops vectorize and at what
# width, so a committed report would describe someone else's CPU), and the tree is
# created on demand per kernel. The directory itself is kept (.gitkeep) so an
# enabled run has a root to write under without the first one having to mkdir it.
perf_reports/**
!perf_reports/.gitkeep
