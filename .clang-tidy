# clang-tidy policy for OptArena's C/C++ (kernels are extern "C" FFI, so the pointer
# ABI is REQUIRED, not a smell). We keep bug-catching + safe modernization and DROP
# the noisy/inapplicable checks:
#   - magic-numbers / c-arrays / macro-usage: benchmark kernels use them by design.
#   - cppcoreguidelines special-member/owning-memory/pro-*: object-oriented ceremony we
#     deliberately avoid (prefer plain functions + data over OO abstractions).
#   - easily-swappable-parameters / include-cleaner: high-noise, low-signal here.
# Header guards: prefer `#pragma once` (so llvm-header-guard is NOT enabled).
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-implicit-widening-of-multiplication-result,
  misc-const-correctness,
  misc-redundant-expression,
  misc-unused-parameters,
  performance-*,
  readability-misleading-indentation,
  readability-redundant-control-flow,
  readability-non-const-parameter,
  modernize-use-nullptr,
  modernize-use-bool-literals,
  modernize-use-override
WarningsAsErrors: ''
HeaderFilterRegex: ''
FormatStyle: file
